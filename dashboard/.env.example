APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# NeoEssentials mod connection — see config/minecraft.php for details.
# Point this at 127.0.0.1 if the dashboard runs on the same box as the MC
# server ("internal"), or at the server's public address/tunnel if hosted
# elsewhere ("external"). Same app either way, just a different URL.
MC_API_URL=http://127.0.0.1:8642
# The pairing-minted API key, webhook token, and WebSocket port used to be here
# (MC_SERVICE_API_KEY/MOD_WEBHOOK_TOKEN/MC_WS_PORT) — pairing now stores them in the
# mc_connection database table instead (see App\Models\McConnection), so there's nothing to
# set here by hand or via pairing anymore.
MC_API_TIMEOUT=4
MC_API_CACHE_TTL=3

# Reverb — self-hosted Pusher-protocol broadcast server the browser connects to for live
# dashboard updates (server status, chat, player join/leave). Never talks to the mod's API
# key directly; a separate backend process (see `dashboard:mc-bridge`) bridges the mod's own
# WebSocket server into this. Run `php artisan reverb:install` once to generate real values —
# do NOT reuse these placeholders across deployments.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
